@model CateringApp.Models.MenuItem
@{
    ViewData["Title"] = "Edit Menu Item";
    var existing = ViewBag.ExistingKitchenItems as Dictionary<int, double>
        ?? new Dictionary<int, double>();
    var availableItems = ViewBag.AvailableItems as List<CateringApp.Models.Item>
        ?? new List<CateringApp.Models.Item>();
}

<div class="create-container">
    <h3>Edit Menu Item</h3>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input type="text" asp-for="Name" class="form-control warm-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Description"></label>
            <input type="text" asp-for="Description" class="form-control warm-input" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Price"></label>
            <input type="text" asp-for="Price" class="form-control warm-input" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="CookingMethod"></label>
            <select asp-for="CookingMethod" asp-items="ViewBag.CookingMethods"
                    class="form-control warm-input">
                <option value="">-- Select Cooking Method --</option>
            </select>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Serves"></label>
            <input type="number" asp-for="Serves"
                   class="form-control warm-input" min="1" />
            <span asp-validation-for="Serves" class="text-danger"></span>
        </div>

        @* Ingredients table *@
        <table class="table mt-4">
            <thead>
                <tr>
                    <th>Include</th>
                    <th>Ingredient</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in availableItems
                                .Where(i => i.Category?.Name == "Ingredients"))
                {
                    var isChecked = existing.ContainsKey(item.Id);
                    var qty = isChecked
                    ? existing[item.Id].ToString(
                    System.Globalization.CultureInfo.InvariantCulture)
                    : "";

                    <tr>
                        <td>
                            <input type="checkbox"
                                   name="selectedItemIds"
                                   value="@item.Id"
                                   onchange="toggleQty(this)"
                                   @(isChecked ? "checked" : "")
                                   style="accent-color:#a0522d;
                                              width:16px; height:16px;" />
                        </td>
                        <td>
                            <label style="color:#3b2410; margin:0;">
                                @item.Name (@item.Unit)
                            </label>
                        </td>
                        <td>
                            <input type="number"
                                   name="quantities_@item.Id"
                                   value="@qty"
                                   min="0" step="0.01"
                                   placeholder="0"
                                   class="form-control warm-input"
                                   style="width:100px;"
                                   @(isChecked ? "" : "disabled") />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-4">
            <button type="submit" class="btn-warm">Save Changes</button>
            <a asp-action="Index" class="btn-warm btn-warm-cancel">Cancel</a>
        </div>
    </form>
</div>

<script>
    function toggleQty(checkbox) {
        const row = checkbox.closest('tr');
        const qtyInput = row.querySelector('input[type="number"]');
        qtyInput.disabled = !checkbox.checked;
        if (!checkbox.checked) qtyInput.value = '';
    }
</script>

@await Html.PartialAsync("_WarmFormStyles")

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}