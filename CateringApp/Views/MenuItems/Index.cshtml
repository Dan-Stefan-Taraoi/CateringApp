@model List<CateringApp.Models.MenuItem>
@{
    ViewData["Title"] = "Menu";
}

<div class="menu-container">
    <div class="menu-header">
        <h3>Menu</h3>
        <a asp-action="Create" class="btn-warm">+ Add to Menu</a>
    </div>

    @if (!Model.Any())
    {
        <p class="empty-note">No menu items yet.</p>
    }
    else
    {
        <table class="table items-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Cooking Method</th>
                    <th>Serves</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.Price.ToString("N2") €</td>
                        <td>@item.CookingMethod</td>
                        <td>@item.Serves</td>
                        <td class="actions-cell">
                            <a class="btn-action btn-edit" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            <a class="btn-action btn-delete" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<style>
    .menu-container {
        padding: 1.5rem 0;
    }

    .menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

        .menu-header h3 {
            color: #5a3010;
            font-weight: 500;
            margin: 0;
        }

    .empty-note {
        color: #5a3010;
        opacity: 0.6;
        font-style: italic;
    }

    /* reusing the same table styles as Inventory */
    .items-table {
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
    }

        .items-table thead tr {
            background-color: #e8d5b0;
        }

        .items-table thead th {
            color: #3b2410;
            font-weight: 600;
            border-bottom: 2px solid #d4b896;
            padding: 0.85rem 1rem;
        }

        .items-table tbody tr {
            border-bottom: 1px solid #eddfc8;
            transition: background-color 0.2s ease;
        }

            .items-table tbody tr:last-child {
                border-bottom: none;
            }

            .items-table tbody tr:hover {
                background-color: #f5e9d5;
            }

        .items-table td {
            color: #3b2410;
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }

    .actions-cell {
        white-space: nowrap;
    }

    .btn-warm {
        display: inline-block;
        padding: 8px 20px;
        background-color: #a0522d;
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: opacity 0.2s ease;
    }

        .btn-warm:hover {
            opacity: 0.85;
            color: #fff;
            text-decoration: none;
        }

    .btn-action {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 4px;
        font-size: 0.85rem;
        text-decoration: none;
        margin-right: 4px;
        transition: opacity 0.2s ease;
    }

        .btn-action:hover {
            opacity: 0.8;
            text-decoration: none;
        }

    .btn-edit {
        background-color: #c8a96e;
        color: #fff;
    }

    .btn-delete {
        background-color: #a0522d;
        color: #fff;
    }
</style>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}