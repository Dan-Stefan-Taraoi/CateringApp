@model CateringApp.Models.Item
@{
    ViewData["Title"] = "Delete";
}

<div class="delete-container">
    <h3>Remove Item</h3>
    <p class="delete-warning">Are you sure you want to delete this item?</p>

    <div class="delete-card">
        <div class="delete-row">
            <span class="delete-label">Name</span>
            <span>@Model.Name</span>
        </div>
        <div class="delete-row">
            <span class="delete-label">Description</span>
            <span>@Model.Description</span>
        </div>
        <div class="delete-row">
            <span class="delete-label">Price</span>
            <span>@Model.Price.ToString("N2") €</span>
        </div>
        <div class="delete-row">
            <span class="delete-label">Category</span>
            <span>@(Model.Category?.Name ?? "---")</span>
        </div>
        <div class="delete-row">
            <span class="delete-label">Clients</span>
            <span>
                @if (Model.ItemClients != null && Model.ItemClients.Any())
                {
                    @foreach (var ic in Model.ItemClients)
                    {
                        <span class="client-tag">@ic.Client.Name</span>
                    }
                }
                else
                {
                    <span class="text-muted">---</span>
                }
            </span>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn-warm btn-warm-danger">Yes, Delete</button>
        <a asp-action="Index" class="btn-warm btn-warm-cancel">Cancel</a>
    </form>
</div>

<style>
    .delete-container {
        width: 50%;
        margin-top: 1.5rem;
    }

        .delete-container h3 {
            color: #5a3010;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

    .delete-warning {
        color: #a0522d;
        margin-bottom: 1.25rem;
    }

    .delete-card {
        background-color: #fdf7f0;
        border: 1px solid #e0c9aa;
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
    }

    .delete-row {
        display: flex;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #eddfc8;
        color: #3b2410;
        align-items: flex-start;
    }

        .delete-row:last-child {
            border-bottom: none;
        }

    .delete-label {
        font-weight: 600;
        min-width: 140px;
        color: #5a3010;
    }

    .client-tag {
        display: inline-block;
        background-color: #e8d5b0;
        color: #3b2410;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: 0.85rem;
        margin: 2px;
    }

    .btn-warm {
        display: inline-block;
        padding: 8px 24px;
        background-color: #a0522d;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 0.95rem;
        cursor: pointer;
        text-decoration: none;
        transition: opacity 0.2s ease;
        margin-right: 8px;
    }

        .btn-warm:hover {
            opacity: 0.85;
            color: #fff;
            text-decoration: none;
        }

    .btn-warm-danger {
        background-color: #8b1a1a;
    }

    .btn-warm-cancel {
        background-color: transparent;
        border: 2px solid #a0522d;
        color: #a0522d;
    }

        .btn-warm-cancel:hover {
            background-color: #a0522d;
            color: #fff;
        }
</style>