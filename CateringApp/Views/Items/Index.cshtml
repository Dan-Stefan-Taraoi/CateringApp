@model List<CateringApp.Models.Item>

@{
    // setting the title of the page (a variable Viewdata that works with 'key-value'  pairs)
    ViewData["Title"] = "Items";
}

<h3>Index</h3>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Price</th>
            <th>SerialNumber</th>
            <th>Category</th>
            <th>Clients</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price.ToString("N2") €</td>
                <td>@item.SerialNumber?.Name</td>
                <td>@item.Category?.Name</td>
                <td>
                    @if (item.ItemClients != null && item.ItemClients.Any())
                    {
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            @foreach (var client in item.ItemClients)
                            {
                                <li>@client.Client.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p> --- </p>
                    }
                </td>
               <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
