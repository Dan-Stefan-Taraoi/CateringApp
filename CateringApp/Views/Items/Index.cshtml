@model List<CateringApp.Models.Item>
@{
    ViewData["Title"] = "Items";
}

<div class="items-container">
    <h3>Inventory</h3>
    <table class="table items-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Category</th>
                <th>Clients</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Price.ToString("N2") €</td>
                    <td>@(item.Category?.Name ?? "---")</td>
                    <td>
                        @if (item.ItemClients != null && item.ItemClients.Any())
                        {
                            @foreach (var ic in item.ItemClients)
                            {
                                <span class="client-tag">@ic.Client.Name</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">---</span>
                        }
                    </td>
                    <td class="actions-cell">
                        <a class="btn-action btn-edit" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn-action btn-delete" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .items-container {
        padding: 1.5rem 0;
    }

        .items-container h3 {
            color: #5a3010;
            margin-bottom: 1.25rem;
            font-weight: 500;
            letter-spacing: 1px;
        }

    .items-table {
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
    }

        .items-table thead tr {
            background-color: #e8d5b0;
        }

        .items-table thead th {
            color: #3b2410;
            font-weight: 600;
            border-bottom: 2px solid #d4b896;
            padding: 0.85rem 1rem;
        }

        .items-table tbody tr {
            border-bottom: 1px solid #eddfc8;
            transition: background-color 0.2s ease;
        }

            .items-table tbody tr:last-child {
                border-bottom: none;
            }

            .items-table tbody tr:hover {
                background-color: #f5e9d5;
            }

        .items-table td {
            color: #3b2410;
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }

/*     .client-tag {
        display: inline-block;
        background-color: #e8d5b0;
        color: #3b2410;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: 0.85rem;
        margin: 2px;
    } */

    .actions-cell {
        white-space: nowrap;
    }

    .btn-action {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 4px;
        font-size: 0.85rem;
        text-decoration: none;
        margin-right: 4px;
        transition: opacity 0.2s ease;
    }

        .btn-action:hover {
            opacity: 0.8;
            text-decoration: none;
        }

    .btn-edit {
        background-color: #c8a96e;
        color: #fff;
    }

    .btn-delete {
        background-color: #a0522d;
        color: #fff;
    }
</style>