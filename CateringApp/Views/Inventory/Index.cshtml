@model Dictionary<string, List<CateringApp.Models.Item>>
@{
    ViewData["Title"] = "Inventory";
}

<div class="items-container">
    <div class="menu-header">
        <h3>Inventory</h3>
        <a asp-action="Create" class="btn-warm">+ Add Item</a>
    </div>

    @if (!Model.Any())
    {
        <p class="empty-note">No inventory items yet.</p>
    }
    else
    {
        @foreach (var group in Model)
        {
            <h4 class="group-heading">@group.Key</h4>
            <table class="table items-table mb-4">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Unit</th>
                        <th>Available</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in group.Value)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Price.ToString("N2") €</td>
                            <td>@item.Quantity</td>
                            <td>@(item.Unit ?? "---")</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="availability available">Yes</span>
                                }
                                else
                                {
                                    <span class="availability unavailable">No</span>
                                }
                            </td>
                            <td class="actions-cell">
                                <a class="btn-action btn-edit"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id">Edit</a>
                                <a class="btn-action btn-delete"
                                   asp-action="Delete"
                                   asp-route-id="@item.Id">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

<style>
    .items-container {
        padding: 1.5rem 0;
    }

    .menu-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

        .menu-header h3 {
            color: #5a3010;
            font-weight: 500;
            margin: 0;
        }

    .group-heading {
        color: #5a3010;
        font-weight: 500;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        padding-bottom: 0.25rem;
        border-bottom: 2px solid #e0c9aa;
    }

    .empty-note {
        color: #5a3010;
        opacity: 0.6;
        font-style: italic;
    }

    .items-table {
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
    }

        .items-table thead tr {
            background-color: #e8d5b0;
        }

        .items-table thead th {
            color: #3b2410;
            font-weight: 600;
            border-bottom: 2px solid #d4b896;
            padding: 0.85rem 1rem;
        }

        .items-table tbody tr {
            border-bottom: 1px solid #eddfc8;
            transition: background-color 0.2s ease;
        }

            .items-table tbody tr:last-child {
                border-bottom: none;
            }

            .items-table tbody tr:hover {
                background-color: #f5e9d5;
            }

        .items-table td {
            color: #3b2410;
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }

    .availability {
        display: inline-block;
        border-radius: 4px;
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .available {
        background-color: #d4edda;
        color: #2d6a3f;
    }

    .unavailable {
        background-color: #f8d7da;
        color: #721c24;
    }

    .actions-cell {
        white-space: nowrap;
    }

    .btn-warm {
        display: inline-block;
        padding: 8px 16px;
        background-color: #a0522d;
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: opacity 0.2s ease;
    }

        .btn-warm:hover {
            opacity: 0.85;
            color: #fff;
            text-decoration: none;
        }

    .btn-action {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 4px;
        font-size: 0.85rem;
        text-decoration: none;
        margin-right: 4px;
        transition: opacity 0.2s ease;
    }

        .btn-action:hover {
            opacity: 0.8;
            text-decoration: none;
        }

    .btn-edit {
        background-color: #c8a96e;
        color: #fff;
    }

    .btn-delete {
        background-color: #a0522d;
        color: #fff;
    }
</style>