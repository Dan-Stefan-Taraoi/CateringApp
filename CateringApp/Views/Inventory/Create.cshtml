@model CateringApp.Models.Item
@{
    ViewData["Title"] = "Add Item";
}

<div class="create-container">
    <h3>Add Item</h3>

    <form asp-action="Create" method="post">

        <div class="form-group">
            <label asp-for="Name"></label>
            <input type="text" asp-for="Name" class="form-control warm-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Price"></label>
            <input type="text" asp-for="Price" class="form-control warm-input" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Quantity"></label>
            <input type="number" asp-for="Quantity" class="form-control warm-input" min="0" />
        </div>

        <div class="form-group mt-2">
            <label asp-for="Unit"></label>
            <input type="text" asp-for="Unit" class="form-control warm-input"
                   placeholder="e.g. kg, L, pcs" />
        </div>

        <div class="form-group mt-2">
            <label asp-for="CategoryId">Category</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                    class="form-control warm-input">
                <option value="">-- Select a Category --</option>
            </select>
        </div>

        <div class="form-group mt-2">
            <div class="form-check">
                <input type="checkbox" asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label"
                       style="color: #5a3010;">Available</label>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn-warm">Save</button>
            <a asp-action="Index" class="btn-warm btn-warm-cancel">Cancel</a>
        </div>
    </form>
</div>

@await Html.PartialAsync("_WarmFormStyles")