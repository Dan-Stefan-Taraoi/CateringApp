@model CateringApp.Models.Ingredient
@{
    ViewData["Title"] = "Edit Ingredient";
}

<div class="create-container">
    <h3>Edit Ingredient</h3>

    <form asp-action="EditIngredient" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input type="text" asp-for="Name" class="form-control warm-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Description"></label>
            <input type="text" asp-for="Description" class="form-control warm-input" />
        </div>

        <div class="form-group mt-2">
            <label asp-for="Price"></label>
            <input type="text" asp-for="Price" class="form-control warm-input" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label for="CategoryId">Category</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                    class="form-control warm-input">
                <option value="">-- Select a Category --</option>
            </select>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Unit"></label>
            <input type="text" asp-for="Unit" class="form-control warm-input"
                   placeholder="e.g. kg, L, pcs" />
            <span asp-validation-for="Unit" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Quantity"></label>
            <input type="number" asp-for="Quantity" class="form-control warm-input" min="0" />
        </div>

        <div class="form-group mt-2">
            <label asp-for="Location"></label>
            <input type="text" asp-for="Location" class="form-control warm-input"
                   placeholder="e.g. Kitchen Storage" />
        </div>

        <div class="mt-4">
            <button type="submit" class="btn-warm">Save Changes</button>
            <a asp-action="Index" class="btn-warm btn-warm-cancel">Cancel</a>
        </div>
    </form>
</div>

@{
    await Html.RenderPartialAsync("_WarmFormStyles");
}