@model List<CateringApp.Models.ViewModels.TableStatusViewModel>
@{
    ViewData["Title"] = "Service Map";
}

<body>
    <div class="service-map-container">
        <div class="left-section">
            <div class="map-headerr">
                <h3>Tables Map</h3>
            </div>
            <div class="grid-left-section">
                <div class="grid-content">
                    @if (!Model.Any())
                    {
                        <p class="empty-note">No client items yet.</p>
                    }
                    else
                    {
                        <div class="tables-grid">
                            @foreach (var vm in Model.Where(model => model.Client.Address == "Local"))
                            {
                                <div class="table-box">
                                    <span class="table-name">@vm.Client.Name</span>
                                    @{
                                        var bulbClass = vm.ActiveOrder is null ? "bulb-grey" : // Default class
                                        vm.ActiveOrder.IsPaid ? "bulb-green" : "bulb-red"; // Conditional classes
                                    }
                                    <span class="bulb @bulbClass"></span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="right-section">
            <div class="map-headerr">
                <h3>Catering Clients</h3>
            </div>
            <div class="list-right-section">
                <div class="list-content">
                    <table class="table items-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Address</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Where(model => model.Client.Address != "Local"))
                            {
                                <tr>
                                    <td>@item.Client.Name</td>
                                    <td>@item.Client.Address</td>
                                    @{
                                        var bulbClass = item.ActiveOrder is null ? "bulb-grey" : // Default class
                                        item.ActiveOrder.IsPaid ? "bulb-green" : "bulb-red"; // Conditional classes
                                    }
                                    <td>
                                        <div class="bulb-efficiency">
                                            <span class="bulb @bulbClass"></span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>

<style>
    /* Container for the entire page */
    .service-map-container {
        display: flex;
        height: 100vh; /* or any desired height */
        gap: 20px;
    }

    /* Left grid occupying 75% */
    .grid-left-section {
        flex: 3; /* 75% if total flex units are 4 (3 + 1) */
        padding: 10px;
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
        width: 100%;
    }

    /* Right list occupying 25% */
    .list-right-section {
        flex: 1; /* remaining 25% */
        padding: 10px;
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
        width: 100%;
    }

    .tables-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr); /* Adjust number of columns */
        gap: 10px;
    }

    .table-box {
        background-color: #e8d5b0;
        border: 2px solid #333;
        border-radius: 8px;
        height: 80px; /* fixed height for each table */
        gap: 0.75rem;
        padding: 0.75rem;
        border: 1px solid;
        border-color: #a0522d;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-weight: bold;
        transition: background-color 0.3s ease;
    }



    /* intoduced----------------------------------------------------------------------------------------------- */
    .history-container {
        padding: 1.5rem 0;
    }

    .map-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

        .map-header h3 {
            color: #5a3010;
            font-weight: 500;
            margin: 0;
        }

    .empty-note {
        color: #5a3010;
        opacity: 0.6;
        font-style: italic;
    }

    .items-table {
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
        width: 100%;
    }

        .items-table thead tr {
            background-color: #e8d5b0;
        }

        .items-table thead th {
            color: #3b2410;
            font-weight: 600;
            border-bottom: 2px solid #d4b896;
            padding: 0.85rem 1rem;
        }

    .order-row {
        border-bottom: 1px solid #eddfc8;
        transition: background-color 0.2s ease;
        cursor: pointer;
    }

        .order-row:hover {
            background-color: #f5e9d5;
        }

    .items-table td {
        color: #3b2410;
        padding: 0.75rem 1rem;
        vertical-align: middle;
    }

    /* intoduced----------------------------------------------------------------------------------------------- */

    .bulb-efficiency {
        background-color: transparent;
        border: 2px solid #333;
        border-radius: 8px;
        gap: 0.75rem;
        height: 12px;
        padding: 0.75rem;
        border: 1px solid #e0c9aa;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-weight: bold;
        transition: background-color 0.3s ease;
    }

    .table-box:hover {
        background-color: #6fa0c2;
    }

    .table-name {
        padding: 5px;
    }

    .bulb-red {
        background: #e74c3c;
        border-radius: 50%;
        width: 14px;
        height: 14px;
    }

    .bulb-green {
        background: #2ecc71;
        border-radius: 50%;
        width: 14px;
        height: 14px;
    }

    .bulb-grey {
        background: #bdc3c7;
        border-radius: 50%;
        width: 14px;
        height: 14px;
    }

</style>