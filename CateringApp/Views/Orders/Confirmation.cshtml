@model CateringApp.Models.OrderDetails
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="order-container">
    <h3>Order Confirmed</h3>

    <div class="order-section">
        <h5>Order Details</h5>
        <div class="delete-row">
            <span class="delete-label">Client</span>
            <span>@Model.Client.Name</span>
        </div>
        <div class="delete-row">
            <span class="delete-label">Service Type</span>
            <span>
                @if (Model.IsTableService)
                {
                    <span class="type-badge" style="background:#d4edda;color:#2d6a3f;">Restaurant</span>
                }
                else
                {
                    <span class="type-badge" style="background:#d0e8f5;color:#1a4f6e;">Catering</span>
                }
            </span>
        </div>
        @if (Model.RequiresTransport)
        {
            <div class="delete-row">
                <span class="delete-label">Transport</span>
                <span>Required</span>
            </div>
        }
        @if (Model.IsBulkPackaged)
        {
            <div class="delete-row">
                <span class="delete-label">Packaging</span>
                <span>Bulk packaged</span>
            </div>
        }
    </div>

    <div class="order-section">
        <h5>Dishes</h5>
        <table class="table items-table">
            <thead>
                <tr>
                    <th>Dish</th>
                    <th>Ingredients</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dish in Model.Dishes)
                {
                    <tr>
                        <td>
                            @if (dish is CateringApp.Models.RestaurantDish)
                            {
                                <span class="type-badge" style="background:#d4edda;color:#2d6a3f;">Restaurant</span>
                            }
                            else if (dish is CateringApp.Models.CateringDish)
                            {
                                <span class="type-badge" style="background:#d0e8f5;color:#1a4f6e;">Catering</span>
                            }
                        </td>
                        <td>
                            @foreach (var ingredient in dish.GetIngredients())
                            {
                                <span class="client-tag">@ingredient.Name</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4">
        <a asp-action="Place" class="btn-warm">New Order</a>
        <a asp-controller="Home" asp-action="Index" class="btn-warm btn-warm-cancel">Home</a>
    </div>
</div>

@await Html.PartialAsync("_WarmFormStyles")

<style>
    .order-container {
        max-width: 860px;
        padding: 1.5rem 0;
    }

        .order-container h3 {
            color: #5a3010;
            font-weight: 500;
            margin-bottom: 1.5rem;
        }

    .order-section {
        background-color: #fdf7f0;
        border: 1px solid #e0c9aa;
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
    }

        .order-section h5 {
            color: #5a3010;
            font-weight: 500;
            margin-bottom: 0.75rem;
        }

    .delete-row {
        display: flex;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #eddfc8;
        color: #3b2410;
    }

        .delete-row:last-child {
            border-bottom: none;
        }

    .delete-label {
        font-weight: 600;
        min-width: 140px;
        color: #5a3010;
    }

    .type-badge {
        display: inline-block;
        border-radius: 4px;
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .client-tag {
        display: inline-block;
        background-color: #e8d5b0;
        color: #3b2410;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: 0.85rem;
        margin: 2px;
    }

    .items-table {
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
        width: 100%;
    }

        .items-table thead tr {
            background-color: #e8d5b0;
        }

        .items-table thead th {
            color: #3b2410;
            font-weight: 600;
            border-bottom: 2px solid #d4b896;
            padding: 0.75rem 1rem;
        }

        .items-table td {
            color: #3b2410;
            padding: 0.75rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #eddfc8;
        }
</style>