@model List<CateringApp.Models.Order>
@{
    ViewData["Title"] = "Order History";
}

<div class="history-container">
    <div class="history-header">
        <h3>Order History</h3>
        <a asp-action="Place" class="btn-warm">+ New Order</a>
    </div>

    @if (!Model.Any())
    {
        <p class="empty-note">No orders yet.</p>
    }
    else
    {
        <table class="table items-table">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Paid</th>
                    <th>Order Date</th>
                    <th>Service Type</th>
                    <th>Total Price</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Client.Name</td>
                        <td>
                            @if (order.IsPaid)
                            {
                                <span class="paid-badge">Paid</span>
                            }
                            else
                            {
                                <span class="unpaid-badge">Unpaid</span>
                            }
                        </td>
                        <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (order.ServiceType == "Restaurant")
                            {
                                <span class="type-badge badge-restaurant">Restaurant</span>
                            }
                            else
                            {
                                <span class="type-badge badge-catering">Catering</span>
                            }
                        </td>
                        <td>@order.Total.ToString("N2") €</td>
                        <td class="actions-cell">
                            @if (!order.IsPaid)
                            {
                                <form asp-action="PayOrder" asp-route-id="@order.Id"
                                      method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action btn-pay">Pay</button>
                                </form>
                            }
                            <form asp-action="DeleteOrder" asp-route-id="@order.Id"
                                  method="post" style="display:inline;"
                                  onsubmit="return confirm('Delete this order?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-action btn-delete">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<style>
    .history-container {
        padding: 1.5rem 0;
    }

    .history-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

        .history-header h3 {
            color: #5a3010;
            font-weight: 500;
            margin: 0;
        }

    .empty-note {
        color: #5a3010;
        opacity: 0.6;
        font-style: italic;
    }

    .items-table {
        background-color: #fdf7f0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e0c9aa;
        width: 100%;
    }

        .items-table thead tr {
            background-color: #e8d5b0;
        }

        .items-table thead th {
            color: #3b2410;
            font-weight: 600;
            border-bottom: 2px solid #d4b896;
            padding: 0.85rem 1rem;
        }

        .items-table tbody tr {
            border-bottom: 1px solid #eddfc8;
            transition: background-color 0.2s ease;
        }

            .items-table tbody tr:last-child {
                border-bottom: none;
            }

            .items-table tbody tr:hover {
                background-color: #f5e9d5;
            }

        .items-table td {
            color: #3b2410;
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }

    .actions-cell {
        white-space: nowrap;
    }

    .type-badge {
        display: inline-block;
        border-radius: 4px;
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .badge-restaurant {
        background-color: #d4edda;
        color: #2d6a3f;
    }

    .badge-catering {
        background-color: #d0e8f5;
        color: #1a4f6e;
    }

    .paid-badge {
        display: inline-block;
        background-color: #d4edda;
        color: #2d6a3f;
        border-radius: 4px;
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .unpaid-badge {
        display: inline-block;
        background-color: #fff3cd;
        color: #856404;
        border-radius: 4px;
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .btn-warm {
        display: inline-block;
        padding: 8px 20px;
        background-color: #a0522d;
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: opacity 0.2s ease;
    }

        .btn-warm:hover {
            opacity: 0.85;
            color: #fff;
            text-decoration: none;
        }

    .btn-action {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 4px;
        font-size: 0.85rem;
        text-decoration: none;
        margin-right: 4px;
        transition: opacity 0.2s ease;
        border: none;
        cursor: pointer;
    }

        .btn-action:hover {
            opacity: 0.8;
        }

    .btn-pay {
        background-color: #4a7fc1;
        color: #fff;
    }

    .btn-delete {
        background-color: #8b1a1a;
        color: #fff;
    }
</style>